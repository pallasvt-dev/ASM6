@{
    ViewData["Title"] = "Trang chủ";
    var categories = ViewBag.Categories as List<QLBanHang.Models.Category>;
    var products = Model as IEnumerable<QLBanHang.Models.Product>;
}

<div class="row">
    <div class="col-md-3">
        <h5>Danh mục sản phẩm</h5>
        <ul class="list-group">
            <li class="list-group-item">
                <a asp-action="Index">Tất cả sản phẩm</a>
            </li>
            @if (categories != null)
            {
                @foreach (var cat in categories)
                {
                    <li class="list-group-item">
                        <a asp-action="GetProductsByCategory" asp-route-categoryId="@cat.Id">@cat.Name</a>
                    </li>
                }
            }
        </ul>
    </div>

    <div class="col-md-9">
        <h3>Danh sách sản phẩm</h3>
        @if (products == null || !products.Any())
        {
            <p>Không có sản phẩm nào.</p>
        }
        else
        {
            <div class="row">
                @foreach (var item in products!)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card h-100">
                            @if (!string.IsNullOrEmpty(item.Image))
                            {
                                <img src="@item.Image" class="card-img-top" alt="@item.Name"
                                     style="height:150px;object-fit:contain;" />
                            }
                            <div class="card-body">
                                <h6 class="card-title">@item.Name</h6>
                                <p class="card-text text-danger fw-bold">@item.Price.ToString("N0") VNĐ</p>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                    Chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@{
    Layout = "_Layout";
}

@model QLBanHang.Models.Product

<h2>Chi tiết sản phẩm</h2>

<div class="card">
    @if (!string.IsNullOrEmpty(Model.Image))
    {
        <img src="@Model.Image" class="card-img-top" alt="@Model.Name" style="max-height:300px;object-fit:contain;" />
    }
    <div class="card-body">
        <h3 class="card-title">@Model.Name</h3>
        <p class="card-text">@Model.Description</p>
        <h4 class="text-danger">@Model.Price.ToString("N0") VNĐ</h4>
        <p><strong>Danh mục:</strong> @Model.Category?.Name</p>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary">Quay lại</a>

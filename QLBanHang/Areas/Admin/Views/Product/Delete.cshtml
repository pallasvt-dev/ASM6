@model QLBanHang.Models.Product
@{
    ViewData["Title"] = "Xóa Sản phẩm";
}

<h2 class="text-danger">Xác nhận xóa sản phẩm</h2>

<div class="alert alert-danger">
    <h3>Bạn có chắc chắn muốn xóa sản phẩm này không?</h3>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Tên</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Giá</dt>
        <dd class="col-sm-10">@Model.Price.ToString("N0") VNĐ</dd>
        <dt class="col-sm-2">Chủ đề</dt>
        <dd class="col-sm-10">@Model.Category?.Name</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Xóa</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </form>
</div>
